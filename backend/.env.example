# Port d'écoute du serveur
PORT=3001

# Environnement : development | staging | production
NODE_ENV=development

# Connexion MongoDB (Cosmos DB en production)
# IMPORTANT : Ne jamais committer cette valeur dans Git !
# En production, elle est injectée depuis Azure Key Vault via les pipelines.
MONGODB_URI=mongodb://localhost:27017/coissant

# Origines autorisées pour le CORS
ALLOWED_ORIGINS=http://localhost:5173
